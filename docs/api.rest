@baseUrl = http://localhost:5000
#@ip = 14.152.94.1
@ip = 192.168.2.2
@mail = admin@local
@password = admin

###
# @name oauth_login
POST {{baseUrl}}/api/oauth/login
Content-Type: application/json

{
  "email": "{{mail}}",
  "password": "{{password}}"
}

###
# Captura automática dos tokens
@access_token = {{oauth_login.response.body.access_token}}
@refresh_token = {{oauth_login.response.body.refresh_token}}

###
# @name oauth_refresh
GET {{baseUrl}}/api/oauth/token
Content-Type: application/json
Refresh-Token: {{refresh_token}}

###
# Captura automática dos tokens
@access_token = {{oauth_refresh.response.body.access_token}}

###

# @name Info
# Retrieves comprehensive GeoIP, ASN, and reputation data for a specific IP address.
GET {{baseUrl}}/api/ip/info/{{ip}}
content-type: application/json

response_headers:
```
Content-Type: application/json
x-risk-score: 9
x-country-code: CN
x-cache: miss
x-ignore: false
```

