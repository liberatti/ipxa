# @name Check
# Simplified response focused on reputation and risk assessment.
GET {{baseUrl}}/api/ip/check/{{ip}}

response_headers:
```
Content-Type: application/json
x-risk-score: 9
x-cache: miss
x-ignore: false
```

response:
```json
{
  "ip": "14.152.94.1",
  "reasons": [
    "rbl:firehol_level1"
  ],
  "risk_score": 9
}
```
###

# @name Quick
# Optimized for firewalls and middleware. Returns risk score in body and X-Risk-Score header.
GET {{baseUrl}}/api/ip/quick/{{ip}}

response_headers:
```
Content-Type: application/json
x-risk-score: 9
x-cache: miss
x-ignore: false
```

response:
```json
{
  "risk_score": 9
}
```

###
# @name UsersList
GET {{baseUrl}}/api/user
Authorization: Bearer {{access_token}}

###
# @name UserCreate
POST {{baseUrl}}/api/user
Content-Type: application/json
Authorization: Bearer {{access_token}}

{
  "name": "New User",
  "email": "newuser@local",
  "password": "password123",
  "role": "viewer"
}

###
# @name UserGet
@user_id = {{UsersList.response.body.data[0]._id}}
GET {{baseUrl}}/api/user/{{user_id}}
Authorization: Bearer {{access_token}}

###
# @name UserUpdate
PUT {{baseUrl}}/api/user/{{user_id}}
Content-Type: application/json
Authorization: Bearer {{access_token}}

{
  "name": "Updated User",
  "role": "viewer"
}

###
# @name UserDelete
DELETE {{baseUrl}}/api/user/{{user_id}}
Authorization: Bearer {{access_token}}

